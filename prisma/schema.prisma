generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}



model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           String          @default("STUDENT")
  xp             Int             @default(0)
  coins          Int             @default(0)
  level          Int             @default(1)
  currentStreak  Int             @default(0)
  longestStreak  Int             @default(0)
  bio            String          @default("")
  skills         String          @default("")
  github         String          @default("")
  linkedin       String          @default("")
  departmentId   String?
  department     Department?     @relation("DepartmentUsers", fields: [departmentId], references: [id])
  hodDepartment  Department?     @relation("DepartmentHOD")
  
  stageProgresses  StageProgress[]
  submissions      Submission[]
  badges           UserBadge[]
  stage1Activities Stage1Activity[]
  stage4Activities Stage4Activity[] @relation("Stage4Activities")
  ownedProjects    Project[]       @relation("OwnedProjects")
  teamMemberships  TeamMember[]    @relation("TeamMemberships")
  teamMessages     Message[]       @relation("TeamMessages")
  
  // Relations for classrooms, mail, courses
  enrolledClassrooms    Classroom[]            @relation("EnrolledClassrooms")
  facultyClassrooms     Classroom[]            @relation("FacultyClassrooms")
  classroomInvitations  ClassroomInvitation[]
  sentMails             Mail[]                 @relation("SentMails")
  receivedMails         Mail[]                 @relation("ReceivedMails")
  courseProgresses      LanguageCourseProgress[]
  assignmentSubmissions AssignmentSubmission[]
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Department {
  id      String @id @default(uuid())
  name    String
  hodId   String? @unique
  hod     User?   @relation("DepartmentHOD", fields: [hodId], references: [id])
  users   User[]  @relation("DepartmentUsers")
}

model Stage {
  id                String          @id @default(uuid())
  number            Int             @unique // 1-4
  name              String
  unlockXpThreshold Int             @default(0)
  progresses        StageProgress[]
}

model StageProgress {
  id          String   @id @default(uuid())
  userId      String
  stageId     String
  status      String   @default("LOCKED")
  completedAt DateTime?
  
  user        User     @relation(fields: [userId], references: [id])
  stage       Stage    @relation(fields: [stageId], references: [id])

  @@unique([userId, stageId])
}

model Problem {
  id              String       @id @default(uuid())
  title           String
  description     String
  difficulty      String
  languageSupport String       // e.g., "javascript,python,cpp" or JSON
  testCases       String       // JSON string of test cases
  submissions     Submission[]
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  problemId   String
  code        String
  language    String
  status      String
  xpAwarded   Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Stage1Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "READING", "LISTENING", "WRITING", "SPEAKING"
  score       Int      @default(0)
  xpAwarded   Int      @default(0)
  feedback    String?  // Can store JSON string for structured feedback
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String?
  content     Stage1Content? @relation(fields: [contentId], references: [id], onDelete: SetNull)
}

model Stage1Content {
  id          String   @id @default(cuid())
  type        String   // "READING", "LISTENING", "WRITING", "SPEAKING"
  title       String
  content     String   // The passage, prompt, or audio text
  questions   String?  // JSON string of MCQ questions or blanks
  difficulty  String   @default("medium")
  isActive    Boolean  @default(true)
  
  activities  Stage1Activity[]
}

model ProblemStatement {
  id          String   @id @default(uuid())
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  projects    Project[]
}

model Project {
  id                 String   @id @default(uuid())
  name               String
  description        String
  ownerId            String
  problemStatementId String?
  status             String   @default("ACTIVE")
  visibility         String   @default("PUBLIC")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner              User              @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  problemStatement   ProblemStatement? @relation(fields: [problemStatementId], references: [id], onDelete: SetNull)
  files              ProjectFile[]
  team               Team?
}

model ProjectFile {
  id        String   @id @default(uuid())
  projectId String
  path      String
  content   String
  language  String   @default("plaintext")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  projectId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  messages  Message[]
}

model TeamMember {
  id         String   @id @default(uuid())
  teamId     String
  userId     String
  roleInTeam String   @default("MEMBER")
  joinedAt   DateTime @default(now())

  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User     @relation("TeamMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Message {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation("TeamMessages", fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(uuid())
  name        String
  description String
  iconUrl     String
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model DailyChallenge {
  id         String   @id @default(uuid())
  date       DateTime @unique
  difficulty String
  xpReward   Int
  coinReward Int
  type       String   // e.g., "QUIZ", "CODING", "LISTENING"
}

// ==========================================
// Phase E: Stage 4 Career Prep Models
// ==========================================

model AptitudeTest {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // e.g. "QUANTITATIVE", "LOGICAL", "VERBAL"
  questions   String   // JSON string of questions and options
  timeLimit   Int      // in minutes
  isActive    Boolean  @default(true)
  
  activities  Stage4Activity[]
}

model Stage4Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "APTITUDE", "MOCK_INTERVIEW", "RESUME_SCORE"
  score       Int      @default(0)
  xpAwarded   Int      @default(0)
  feedback    String?  // JSON string for interview evaluation or resume feedback
  createdAt   DateTime @default(now())

  user        User     @relation("Stage4Activities", fields: [userId], references: [id], onDelete: Cascade)
  
  // Optional relation if it's an aptitude test
  testId      String?
  test        AptitudeTest? @relation(fields: [testId], references: [id], onDelete: SetNull)
}

// ==========================================
// Classroom & Mail System Models
// ==========================================

model Mail {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMails", fields: [senderId], references: [id])
  recipientId String
  recipient   User     @relation("ReceivedMails", fields: [recipientId], references: [id])
  subject     String
  body        String
  isRead      Boolean  @default(false)
  isStarred   Boolean  @default(false)
  isTrash     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Classroom {
  id           String                @id @default(uuid())
  name         String
  code         String                @unique // 6-char code
  facultyId    String
  faculty      User                  @relation("FacultyClassrooms", fields: [facultyId], references: [id])
  students     User[]                @relation("EnrolledClassrooms")
  invitations  ClassroomInvitation[]
  announcements Announcement[]
  assignments  Assignment[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model ClassroomInvitation {
  id           String    @id @default(uuid())
  classroomId  String
  classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId    String
  student      User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String    @default("PENDING") // "PENDING", "ACCEPTED", "REJECTED"
  createdAt    DateTime  @default(now())

  @@unique([classroomId, studentId])
}

model Announcement {
  id           String    @id @default(uuid())
  classroomId  String
  classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  content      String
  createdAt    DateTime  @default(now())
}

model Assignment {
  id           String    @id @default(uuid())
  classroomId  String
  classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  title        String
  description  String
  dueDate      DateTime
  xpReward     Int       @default(75)
  coinReward   Int       @default(50)
  createdAt    DateTime  @default(now())
  submissions  AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  code         String
  grade        Int?
  feedback     String?
  status       String     @default("SUBMITTED") // "SUBMITTED", "GRADED"
  createdAt    DateTime   @default(now())

  @@unique([assignmentId, studentId])
}

model LanguageCourseProgress {
  id                 String   @id @default(uuid())
  userId             String
  language           String   // "C", "CPP", "PYTHON"
  completedExercises Int      @default(0)
  totalCredits       Int      @default(0)
  currentStreak      Int      @default(0)
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, language])
}

model FileVersion {
  id        String   @id @default(uuid())
  fileId    String
  content   String
  updatedBy String
  createdAt DateTime @default(now())
}

