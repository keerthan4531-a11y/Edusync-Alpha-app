# Flowclass monorepo - single .env at root for all apps (api, web, admin)
# Copy to .env and fill in values: cp .env.example .env

# === API ===
NODE_ENV=development
APP_PORT=5000
# Local path for uploads. For Docker: /workspace/uploads. For local dev: ./uploads
FILE_UPLOAD_LOCATION=./uploads
FILE_UPLOAD_MAX_FILE_SIZE=10485760

# Database - use localhost when API runs locally and postgres runs in Docker (pnpm start / pnpm dev)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=flowclass
DATABASE_SSL=false

# Email: tries SMTP first, automatically falls back to OS sendmail if SMTP is unavailable
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Mail sender (used in email templates)
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@localhost
MAIL_FROM_NAME=Flowclass OSS

JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
JWT_SECRET_STUDENT=

STRIPE_SECRET_KEY=
STRIPE_ENDPOINT_SECRET=

SWAGGER_ENABLED=true

# === URLs (API, Web, Admin) ===
API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_WEB_BASE_URL=http://localhost:3001
VITE_ADMIN_BASE_URL=http://localhost:3000

# === Web: local site domain ===
# Set this to the URL of the site you registered in admin (e.g. localhost:3001).
# Used by the web app to resolve /@<school> routes on localhost.
TEST_DOMAIN=localhost:3001

# === Optional (Stripe) ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === FPS by divit ===
# To use FPS by divit, please visit https://divit.com.hk to create a merchant account
# Required for Divit payment encryption. Generate with: openssl rand -hex 32
DIVIT_ENCRYPTION_KEY=
# Required for testing Divit webhook callbacks. Must be a publicly reachable URL (e.g. an ngrok tunnel).
# Leave empty if not using Divit payments or it will use the default API_BASE_URL.
DIVIT_WEBHOOK_BASE_URL=
