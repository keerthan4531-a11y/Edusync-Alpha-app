{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowUmdGlobalAccess": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "plugins": [
    {
      "name": "next"
    }
  ],

  "include": [
    "./src/**/*",
    ".eslintrc.js",
    "tailwind.config.ts",
    "postcss.config.cjs"
  ],

  "exclude": [
    "/**/node_modules/*",
    "node_modules",
    "**/*.spec.ts",
    "node_modules/**/*",
    ".idea/*",
    ".storybook/*",
    "tests/**/*",
    ".eslintrc.js",
    "*.config.js",
    "*.config.ts"
  ],
  "baseUrl": "."
}
