{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "templates/**/*",
        "watchAssets": true,
        "outDir": "dist/src"
      },
      {
        "include": "common/email-templates/**/*",
        "watchAssets": true,
        "outDir": "dist/src"
      }
    ]
  }
}
